{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Solution Junky",
  "version": "0.1.0",
  "identifier": "com.solutionjunky.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Solution Junky",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "center": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["WebView2Loader.dll"]
  },
  "plugins": {
    "sql": {
      "preloadConnections": [
        "sqlite:solution_junky.db"
      ]
    }
  }
}
